# Anthropic AI — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_PATH=./data/crm.db

# Auth (for the dashboard)
JWT_SECRET=change-this-to-a-random-32-char-string
JWT_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# CRM Settings
CRM_DEFAULT_SLA_HOT=3600
CRM_DEFAULT_SLA_WARM=14400
CRM_DEFAULT_SLA_COLD=86400
